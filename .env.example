# Salin file ini jadi .env lalu isi API key milikmu sendiri.
# JANGAN commit file .env (yang berisi key asli) ke GitHub.

# ── External API Keys ──────────────────────────────────────────────────────────
TOMTOM_API_KEY=GMLNd7y91dUqPCIyi53rxwH2MIAhja4O

# ── Database (Medallion Lakehouse) ─────────────────────────────────────────────
POSTGRES_DB=fuelwatch
POSTGRES_USER=fuelwatch
POSTGRES_PASSWORD=fuelwatch123
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://fuelwatch:fuelwatch123@localhost:5433/fuelwatch

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# ── Kafka (ingestion layer — Apache KRaft) ─────────────────────────────────────
KAFKA_BROKER=kafka:29092
KAFKA_BOOTSTRAP=localhost:9094

# ── Lakehouse (Parquet Bronze/Silver) ──────────────────────────────────────────
DATA_LAKE_PATH=/data

# ── BBM Event (tanggal kenaikan harga resmi) ───────────────────────────────────
BBM_EVENT_DATE=2026-06-10

# ── App Config ─────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
